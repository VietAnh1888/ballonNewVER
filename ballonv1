        if petItem:IsShiny() then m = m * 1.5 end
        if petItem:IsGolden() then m = m * 2 end
        if petItem:IsRainbow() then m = m * 3 end
        return m
    end

    local function count_keys(tbl)
        local count = 0
        for _ in pairs(tbl) do count = count + 1 end
        return count
    end

