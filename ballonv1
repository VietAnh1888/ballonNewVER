local function safeRequire(path)
    if not path then return nil end
    local ok, res = pcall(require, path)
    return ok and res or nil
end

local function handleBlackScreen()
    local CoreGui = game:GetService("CoreGui")
    local ScreenGui = CoreGui:FindFirstChild("RngBlackScreenGui") or LocalPlayer.PlayerGui:FindFirstChild("RngBlackScreenGui")

    if CONFIG.DISABLE_3D_RENDER then
        if not ScreenGui then
            ScreenGui = Instance.new("ScreenGui")
            ScreenGui.Name = "RngBlackScreenGui"
            ScreenGui.DisplayOrder = 9999998 
            ScreenGui.IgnoreGuiInset = true 
            ScreenGui.ResetOnSpawn = false

            local Frame = Instance.new("Frame")
            Frame.Name = "BlackFrame"
            Frame.Size = UDim2.new(1, 0, 1, 0)
            Frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            Frame.BorderSizePixel = 0
            Frame.Parent = ScreenGui

            local success, _ = pcall(function() ScreenGui.Parent = CoreGui end)
            if not success then
                ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
            end
        end
    else
        if ScreenGui then
            ScreenGui:Destroy()
        end
    end
end

local function optimizeTextures()
    if not CONFIG.OPTIMIZE_TEXTURES then return end

    local ClassTypes = { 
        "Decal", "Texture", "ParticleEmitter", "Trail", "Smoke", "Fire", "Sparkles", 
        "Sky", "Atmosphere", "Clouds", "SunRaysEffect", "BloomEffect", "BlurEffect", 
        "DepthOfFieldEffect", "ColorCorrectionEffect", "PostEffect", "Beam", "Highlight",
        "SpecialMesh", "Mesh", "BlockMesh", "CharacterMesh",
        "Animator", "Animation", "AnimationController", "Pose", "Keyframe", "KeyframeSequence",
        "BillboardGui", "SurfaceGui"
    }

    local function cleanObject(v)
        pcall(function()
            if table.find(ClassTypes, v.ClassName) then
                v:Destroy()
            elseif v:IsA("BasePart") or v:IsA("MeshPart") or v:IsA("Part") then
                v.Material = Enum.Material.SmoothPlastic
                v.Reflectance = 0
                v.CastShadow = false
                v.Transparency = 1 -- Tắt hiển thị toàn bộ các part trong game (cho trong suốt 100%)
            end
        end)
    end

    -- 1. Xóa các đối tượng hiện có trong Workspace
    pcall(function()
        for _, v in ipairs(workspace:GetDescendants()) do
            cleanObject(v)
        end
    end)

    -- 2. Tắt hiệu ứng Lighting & bóng đổ toàn cục
    pcall(function()
        local Lighting = game:GetService("Lighting")
        Lighting.GlobalShadows = false
        Lighting.FogStart = 9e9
        Lighting.FogEnd = 9e9
        Lighting.Brightness = 0
        Lighting.ClockTime = 12
        for _, v in ipairs(Lighting:GetDescendants()) do
            if table.find(ClassTypes, v.ClassName) or v:IsA("PostEffect") then
                pcall(function() v:Destroy() end)
            end
        end
    end)

    -- 3. Xử lý các đối tượng mới xuất hiện
    pcall(function()
        workspace.DescendantAdded:Connect(function(v)
            if not CONFIG.OPTIMIZE_TEXTURES then return end
            task.wait()
            if not v or not v.Parent then return end
            cleanObject(v)
        end)
    end)

    -- 4. Ẩn Pets (tắt hiển thị pet client-side để tránh tốn RAM/CPU vẽ hình)
    pcall(function()
        local things = workspace:FindFirstChild("__THINGS")
        local petsFolder = things and things:FindFirstChild("Pets")
        if petsFolder then
            for _, pet in ipairs(petsFolder:GetChildren()) do
                pcall(function() pet:Destroy() end)
            end
            petsFolder.ChildAdded:Connect(function(pet)
                task.wait()
                pcall(function() pet:Destroy() end)
            end)
        end
    end)

    -- 5. Ẩn NPCs (tắt hiển thị NPC client-side)
    pcall(function()
        local things = workspace:FindFirstChild("__THINGS")
        local npcsFolder = things and things:FindFirstChild("NPCs")
        if npcsFolder then
            for _, npc in ipairs(npcsFolder:GetChildren()) do
                pcall(function() npc:Destroy() end)
            end
            npcsFolder.ChildAdded:Connect(function(npc)
                task.wait()
                pcall(function() npc:Destroy() end)
            end)
        end

        -- Quét bổ sung các mô hình NPC, Merchant, Machine để ẩn
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("Model") and (v.Name:lower():find("npc") or v.Name:lower():find("merchant") or v.Name:lower():find("machine")) then
                for _, part in ipairs(v:GetDescendants()) do
                    if part:IsA("BasePart") then
                        pcall(function() part.Transparency = 1 end)
                    end
                end
            end
        end
    end)

    -- 6. Ẩn người chơi khác (Tối ưu cực mạnh cho giả lập)
    pcall(function()
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                if player.Character then
                    pcall(function() player.Character:Destroy() end)
                end
                player.CharacterAdded:Connect(function(char)
                    task.wait()
                    pcall(function() char:Destroy() end)
                end)
            end
        end
        Players.PlayerAdded:Connect(function(player)
            player.CharacterAdded:Connect(function(char)
                task.wait()
                pcall(function() char:Destroy() end)
            end)
        end)
    end)

    -- 7. Giảm chất lượng hiển thị của Engine xuống mức thấp nhất
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)

    -- 8. Tắt CoreGui của Roblox (Chat, Leaderboard, Backpack...)
    pcall(function()
        local StarterGui = game:GetService("StarterGui")
        StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false)
    end)

    -- 9. Ẩn tất cả ScreenGui phụ của game để giải phóng bộ nhớ đồ họa
    pcall(function()
        local function hideUnwantedGui(gui)
            if gui:IsA("ScreenGui") and gui.Name ~= "Main" and gui.Name ~= "ComboFallbackUI" and gui.Name ~= "RngComboMonitorGui" and gui.Name ~= "NavcHudGui" and gui.Name ~= "RngBlackScreenGui" then
                gui.Enabled = false
            end
        end
        for _, gui in ipairs(LocalPlayer.PlayerGui:GetChildren()) do
            hideUnwantedGui(gui)
        end
        LocalPlayer.PlayerGui.ChildAdded:Connect(function(gui)
            task.wait()
            hideUnwantedGui(gui)
        end)
    end)
end

