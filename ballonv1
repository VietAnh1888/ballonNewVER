local function getZoneProgress()
    local save = nil
    if Save then
        pcall(function() save = Save.Get() end)
    end
    if not save then return nil, "no_save" end

    local result = {}
    local prog = save.RNGEventZoneProgress

    if prog then
        for _, zone in ipairs(ZONE_CONFIG) do
            local entry = prog[zone.id]
            result[zone.id] = {
                unlocked   = entry and entry.Unlocked == true or false,
                breakCount = entry and (entry.BreakCount or 0) or 0,
            }
        end
        return result, "DirectSave"
    end

    for _, zone in ipairs(ZONE_CONFIG) do
        result[zone.id] = { unlocked = zone.order == 1, breakCount = 0 }
    end
    return result, "Fallback"
end
local function getLaneZ()
    local things = workspace:FindFirstChild("__THINGS")
    local instContainer = things and things:FindFirstChild("__INSTANCE_CONTAINER")
    local active = instContainer and instContainer:FindFirstChild("Active")
    local rngInst = active and active:FindFirstChild("RngInstance")
    local breakZones = rngInst and rngInst:FindFirstChild("BREAK_ZONES")
    if breakZones then
        for _, child in ipairs(breakZones:GetChildren()) do
            if child:IsA("BasePart") and child.Name == "BREAK_ZONE" then
                return child.Position.Z
            end
        end
    end

    local _, hrp = getChar()
    if hrp and isInRngInstance() then
        return hrp.Position.Z
    end
    return -5379.42
end

local function isGatePresent(gateX, laneZ)
    local things = workspace:FindFirstChild("__THINGS")
    local instContainer = things and things:FindFirstChild("__INSTANCE_CONTAINER")
    local active = instContainer and instContainer:FindFirstChild("Active")
    local rngInst = active and active:FindFirstChild("RngInstance")
    local gatesFolder = rngInst and rngInst:FindFirstChild("Gates")
    if not gatesFolder then return false end

    for _, child in ipairs(gatesFolder:GetDescendants()) do
        if child:IsA("BasePart") then
            local pos = child.Position
            if math.abs(pos.Z - laneZ) < 20 and math.abs(pos.X - gateX) < 15 then

                local gateHUD = child:FindFirstChild("GateHUD")
                if (gateHUD and gateHUD.Enabled == true) or (child.Transparency < 0.9 and child.CanCollide) then
                    return true
                end
            end
        end
    end
    return false
end

local _lastReportedZoneId = nil

local function getMaxUnlockedZone()
    local saveModule = getSaveModule()
    local rngZonesModule = getRngZonesModule()

    local save = nil
    if saveModule then
        pcall(function() save = saveModule.Get() end)
    end

    local maxZone = ZONE_CONFIG[1]
    local maxOrder = 1

    local apiSuccess = false
    if save and rngZonesModule and rngZonesModule.GetMaxUnlockedZoneId then
        local ok, maxZoneId = pcall(function() return rngZonesModule.GetMaxUnlockedZoneId(save) end)
        if ok and maxZoneId then
            for _, zone in ipairs(ZONE_CONFIG) do
                if zone.id == maxZoneId then
                    maxZone = zone
                    maxOrder = zone.order
                    apiSuccess = true
                    break
                end
            end
        end
    end

    if not apiSuccess and save and save.RNGEventZoneProgress then
        for k, v in pairs(save.RNGEventZoneProgress) do
            if v and v.Unlocked then
                for _, zone in ipairs(ZONE_CONFIG) do
                    if zone.id == k and zone.order > maxOrder then
                        maxZone = zone
                        maxOrder = zone.order
                    end
                end
            end
        end
    end

    local laneZ = getLaneZ()
    if isGatePresent(4542.86, laneZ) then
        if maxOrder > 1 then
            maxZone = ZONE_CONFIG[1]
            maxOrder = 1
        end
    elseif isGatePresent(4795.86, laneZ) then
        if maxOrder > 2 then
            maxZone = ZONE_CONFIG[2]
            maxOrder = 2
        end
    elseif isGatePresent(5048.86, laneZ) then
        if maxOrder > 3 then
            maxZone = ZONE_CONFIG[3]
            maxOrder = 3
        end
    end

    if maxZone.id ~= _lastReportedZoneId then
        _lastReportedZoneId = maxZone.id

    end

    return maxZone, maxOrder, {}
end

local function getDynamicFarmCenter(zone)
    local things = workspace:FindFirstChild("__THINGS")
    local _, hrp = getChar()

    local instContainer = things and things:FindFirstChild("__INSTANCE_CONTAINER")
    local active = instContainer and instContainer:FindFirstChild("Active")
    local rngInst = active and active:FindFirstChild("RngInstance")
    local breakZones = rngInst and rngInst:FindFirstChild("BREAK_ZONES")

    if breakZones then
        local parts = {}
        for _, child in ipairs(breakZones:GetChildren()) do
            if child:IsA("BasePart") and child.Name == "BREAK_ZONE" then
                table.insert(parts, child)
            end
        end
        table.sort(parts, function(a, b) return a.Position.X < b.Position.X end)

        local zoneNode = parts[zone.order]
        if zoneNode then
            mySlotZOffset = zoneNode.Position.Z - zone.farmCenter.Z
            return zoneNode.Position
        end
    end

    if mySlotZOffset then
        return zone.farmCenter + Vector3.new(0, 0, mySlotZOffset)
    end

    if hrp and isInRngInstance() then
        local pX = hrp.Position.X
        for _, z in ipairs(ZONE_CONFIG) do
            if math.abs(pX - z.farmCenter.X) <= 130 then
                mySlotZOffset = hrp.Position.Z - z.farmCenter.Z
                return z.farmCenter + Vector3.new(0, 0, mySlotZOffset)
            end
        end
    end

    local instances = things and things:FindFirstChild("Instances")
    local legacyRngInst = instances and instances:FindFirstChild("RngInstance")
    local breakSpawns = legacyRngInst and legacyRngInst:FindFirstChild("BREAKABLE_SPAWNS")

    if breakSpawns then
        if not mySlotFolder then
            mySlotFolder = breakSpawns:FindFirstChild(LocalPlayer.Name)
                or breakSpawns:FindFirstChild(tostring(LocalPlayer.UserId))
        end

        if mySlotFolder then
            local bestPart = nil
            local minDiff = 999999
            for _, child in ipairs(mySlotFolder:GetDescendants()) do
                if child:IsA("BasePart") then
                    local diff = math.abs(child.Position.X - zone.farmCenter.X)
                    if diff < minDiff then
                        minDiff = diff
                        bestPart = child
                    end
                end
            end
            if bestPart and minDiff < 30 then
                mySlotZOffset = bestPart.Position.Z - zone.farmCenter.Z
                return bestPart.Position
            end
        end

        if not mySlotSuffix then
            if hrp then
                local closestPart = nil
                local minD = 999999
                for _, desc in ipairs(breakSpawns:GetDescendants()) do
                    if desc:IsA("BasePart") then
                        local d = (desc.Position - hrp.Position).Magnitude
                        if d < minD then
                            minD = d
                            closestPart = desc
                        end
                    end
                end
                if closestPart and minD < 100 then
                    local curr = closestPart
                    local suffix = nil
                    while curr and curr ~= breakSpawns do
                        suffix = curr.Name:match("([%s%-_]?%d+)$")
                        if suffix then break end
                        curr = curr.Parent
                    end
                    if suffix then
                        mySlotSuffix = suffix
                    end
                end
            end
        end

        if mySlotSuffix then
            local bestPart = nil
            local minDiff = 999999
            for _, desc in ipairs(breakSpawns:GetDescendants()) do
                if desc:IsA("BasePart") then
                    local curr = desc
                    local hasSuffix = false
                    while curr and curr ~= breakSpawns do
                        if curr.Name:sub(-#mySlotSuffix) == mySlotSuffix then
                            hasSuffix = true
                            break
                        end
                        curr = curr.Parent
                    end
                    if hasSuffix then
                        local diff = math.abs(desc.Position.X - zone.farmCenter.X)
                        if diff < minDiff then
                            minDiff = diff
                            bestPart = desc
                        end
                    end
                end
            end
            if bestPart and minDiff < 30 then
                mySlotZOffset = bestPart.Position.Z - zone.farmCenter.Z
                return bestPart.Position
            end
        end
    end

    return zone.farmCenter
end

local function teleportToZoneCenter(zone)
    local _, hrp = getChar()
    if not hrp then return end

    local target = getDynamicFarmCenter(zone)
    if not target then
        local now = tick()
        if now - _lastWarnTime >= 10 then
            _lastWarnTime = now

        end
        return
    end

    local dist = (hrp.Position - target).Magnitude
    if dist < 40 then
        return
    end
    safeTeleport(CFrame.new(target + Vector3.new(0, 4, 0)), 1.5)
end

local isSellingPets = false

local function navigationLoop()
    if not CONFIG.AUTO_NAVIGATE_ZONE then return end
    task.spawn(function()
        while CONFIG.AUTO_NAVIGATE_ZONE do
            if not isInRngInstance() then
                enterRngInstance()
                task.wait(5)
            else
                if not isSellingPets then
                    local maxZone = getMaxUnlockedZone()
                    if maxZone then
                        local target = getDynamicFarmCenter(maxZone)
                        if target then
                            local _, hrp = getChar()
                            if hrp then
                                local dist = (hrp.Position - target).Magnitude
                                if dist > 40 then
                                    safeTeleport(CFrame.new(target + Vector3.new(0, 4, 0)), 1.5)
                                end
                            end
                        end
                    end
                end
                task.wait(CONFIG.LOOP_INTERVALS.ZONE_CHECK)
            end
        end
    end)
