    if RngEggsDir and RngEggsDir.First and RngEggsDir.First.DropTable and RngEggsDir.First.DropTable.entries then
        pcall(function()
            for _, entry in ipairs(RngEggsDir.First.DropTable.entries) do
                local val = entry.Value
                if val and not val:IsHuge() and not val:IsTitanic() then
                    sellableNames[val:GetId()] = true
                end
            end
        end)
    end

    local OBTAINABLE_FALLBACK = {
        ["Sand Turtle"] = true, ["Sprout Stag"] = true, ["Blossom Fox"] = true,
        ["Error Dragon"] = true, ["Honey Bee"] = true, ["Chameleon"] = true,
        ["Tiedye Elephant"] = true, ["Bubble Bunny"] = true, ["Starry Eye Wolf"] = true,
        ["Sapphire Dragon"] = true, ["Wisp Owl"] = true, ["Mystical Kitsune"] = true,
        ["Surge Wolf"] = true, ["Hydra Cat"] = true, ["Pixel Hippomelon"] = true,
        ["Vibrant Zebra"] = true, ["Holographic Shark"] = true
    }

    local function isSellable(petItem)
        if petItem:IsHuge() or petItem:IsTitanic() then
            return false
        end
        local id = petItem:GetId()
        return (sellableNames[id] == true) or (OBTAINABLE_FALLBACK[id] == true)
    end

    local groups = {}
    local totalPetsChecked = 0
    local sellableCount = 0

    local allPets = {}
    local okAll, resAll = pcall(function() return PetItem:All() end)
    if okAll and resAll then
        for uid, petItem in pairs(resAll) do
            allPets[uid] = petItem
        end

    else

    end

    local saveCount = 0
    for uid, _ in pairs(save.Inventory.Pet) do
        saveCount = saveCount + 1
        if not allPets[uid] then
            local petItem = PetItem:Get(uid)
            if petItem then
                allPets[uid] = petItem
            end
        end
    end

    for uid, petItem in pairs(allPets) do
        totalPetsChecked = totalPetsChecked + 1

        local petId = "unknown"
        pcall(function() petId = petItem:GetId() end)
        local petAmt = 1
        pcall(function() petAmt = petItem:GetAmount() or 1 end)

        local can = isSellable(petItem)

        if can then
            sellableCount = sellableCount + 1
            local pid = petItem:GetId()
            if not groups[pid] then groups[pid] = {} end
            table.insert(groups[pid], {
                uid = uid,
                item = petItem,
                strength = strength(petItem),
                amount = petAmt
            })
        end
    end

    local toSell = {}
    local totalToSell = 0

    for pid, group in pairs(groups) do

        table.sort(group, function(a, b) return a.strength > b.strength end)

        local kept = 0
        for _, info in ipairs(group) do
            local amt = info.amount
            if kept < CONFIG.MAX_PER_TYPE then
                local space = CONFIG.MAX_PER_TYPE - kept
                if amt <= space then

                    kept = kept + amt
                else

                    local keepAmt = space
                    local sellAmt = amt - keepAmt
                    toSell[info.uid] = sellAmt
                    totalToSell = totalToSell + sellAmt
                    kept = CONFIG.MAX_PER_TYPE
                end
            else

                toSell[info.uid] = amt
                totalToSell = totalToSell + amt
            end
        end
    end

    if totalToSell > 0 then
        if not isInRngInstance() then

            return
        end

        local _, hrp = getChar()
        if not hrp then

            return
        end

        isSellingPets = true

