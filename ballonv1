local function farmLoop()
    if not CONFIG.AUTO_FARM then return end

    task.spawn(function()
        local cachedFolder = nil
        local lastAnchorSet = 0
        local function getBreakablesFolder()
            if cachedFolder and cachedFolder.Parent then
                return cachedFolder
            end
            local things = workspace:FindFirstChild("__THINGS")
            local b = things and things:FindFirstChild("Breakables")
            if b then
                cachedFolder = b
                return b
            end
            local ab = workspace:FindFirstChild("ActiveBreakables")
            if ab then
                cachedFolder = ab
                return ab
            end
            local b2 = workspace:FindFirstChild("Breakables")
            if b2 then
                cachedFolder = b2
                return b2
            end
            return nil
        end

        while CONFIG.AUTO_FARM do
            if not isInRngInstance() then
                task.wait(2)
            else
                local _, hrp = getChar()
                if not hrp then
                    task.wait(0.5)
                else
                    local playerPos  = hrp.Position
                    local breakableObjs = {}

                    local folder = getBreakablesFolder()
                    if folder then
                        for _, obj in ipairs(folder:GetChildren()) do
                            local pos
                            if obj:IsA("Model") then
                                local pp = obj.PrimaryPart or obj:FindFirstChildOfClass("BasePart")
                                if pp then pos = pp.Position end
                            elseif obj:IsA("BasePart") then
                                pos = obj.Position
                            end
                            if pos then
                                local d = (pos - playerPos).Magnitude
                                if d <= CONFIG.FARM_RADIUS then
                                    table.insert(breakableObjs, obj)
                                end
                            end
                        end
                    end

                    if #breakableObjs > 0 then
                        pcall(function()

                            local now = tick()
                            if now - lastAnchorSet >= 5 then
                                lastAnchorSet = now
                                Network.Fire("BR_SetAnchor", playerPos)
                            end

                            Network.Fire("Breakables_JoinPetBulk", breakableObjs)
                        end)
                    end

                    task.wait(CONFIG.LOOP_INTERVALS.FARM)
                end
            end
        end
    end)
end

