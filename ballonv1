local function getChar()
    local char = LocalPlayer.Character
    if not char then return nil, nil, nil end
    return char, char:FindFirstChild("HumanoidRootPart"), char:FindFirstChildOfClass("Humanoid")
end

local function safeTeleport(targetCFrame)
    pcall(function()
        local _, hrp = getChar()
        if hrp then
            -- Triệt tiêu hoàn toàn vận tốc để tránh bị quán tính giật quay lại hoặc văng
            pcall(function() hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end)
            pcall(function() hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0) end)
            
            -- Dịch chuyển trực tiếp (Một lần duy nhất, tức thời)
            hrp.CFrame = targetCFrame
        end
    end)
end

local function waitWithTimeout(checkFunc, timeout)
    local elapsed = 0
    while elapsed < timeout do
        if checkFunc() then return true end
        task.wait(0.5)
        elapsed = elapsed + 0.5
    end
    return checkFunc()
end

local function isInRngInstance()
    local _, hrp = getChar()
    if not hrp then return false end
    local p = hrp.Position
    return p.X >= 3850 and p.X <= 5500
       and p.Y >= 2540 and p.Y <= 2730
       and p.Z >= -5700 and p.Z <= -4900
end

local function enterRngInstance()
    if isInRngInstance() then return true end

    -- Cố gắng 1: Dịch chuyển gần sát cổng và điều khiển nhân vật đi bộ vào cổng (chắc chắn kích hoạt Touched của Roblox)
    pcall(function()
        local _, hrp, hum = getChar()
        if hrp and hum then
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            hrp.CFrame = CFrame.new(179.7021484375, 19.00869369506836, -140.54132080078125)
            task.wait(0.2)
            hum:MoveTo(hrp.Position + Vector3.new(0, 0, -5)) -- Đi thẳng về phía trước 5 studs để va chạm vào cổng portal
        end
    end)
    if waitWithTimeout(isInRngInstance, 4) then return true end

    -- Cố gắng 2: Dùng lệnh Join client-side của game
    pcall(function()
        local IC = Client and safeRequire(Client:FindFirstChild("InstanceCmds"))
        if IC and IC.Join then IC.Join("RngInstance") end
    end)
    if waitWithTimeout(isInRngInstance, 4) then return true end

    -- Cố gắng 3: Gửi remote Invoke trực tiếp lên Server để tham gia
    pcall(function() Network.Invoke("Instance_Join", "RngInstance") end)
    return waitWithTimeout(isInRngInstance, 6)
end

